  --color-surface-800: oklch(0.25 0.02 265);
  --color-surface-900: oklch(0.18 0.02 265);
  --color-surface-950: oklch(0.12 0.02 265);
}

/* Scrollbar styling */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: var(--color-surface-300);
  border-radius: 999px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--color-surface-400);
}

/* Number input spinner removal */
input[type="number"]::-webkit-inner-spin-button,
input[type="number"]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
input[type="number"] {
  -moz-appearance: textfield;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Glass card effects */
.glass-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.6);
}

/* Pulse glow for brand accents */
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 oklch(0.55 0.24 345 / 0.4); }
  50% { box-shadow: 0 0 16px 4px oklch(0.55 0.24 345 / 0.15); }
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}
